# AI-Based E-Waste Management System - .gitignore

# ========================================
# SECURITY - NEVER COMMIT THESE FILES!
# ========================================

# Environment variables and secrets
.env
.env.local
.env.production
.env.development
*.key
*.pem
config/secrets.yaml
config/credentials.json

# Azure credentials
.azure/
azure.json
azure-credentials.json
service-principal.json

# Database credentials
db_credentials.txt
database.ini
connection_strings.txt

# API Keys
api_keys.txt
*.token

# ========================================
# PYTHON
# ========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

